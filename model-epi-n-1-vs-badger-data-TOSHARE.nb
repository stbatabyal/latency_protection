Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"initial", " ", "conditions", " ", "for", " ", "TST"}], "+", " ", 
    
    RowBox[{"to", " ", "TB"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"init", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"LL", "[", "k", "]"}], "[", "0", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"Mean", "[", 
            RowBox[{
             RowBox[{"fitdata", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}], "/", "n"}]}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"II", "[", "k", "]"}], "[", "0", "]"}], "\[Equal]", "0"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"S", "[", "0", "]"}], "\[Equal]", "0"}], ",", 
         RowBox[{
          RowBox[{"A", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}]}], "]"}]}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "MTBI", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{"eqns", ",", "init"}], "]"}], ",", "vars", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tmax"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Stot", "[", "tt_", "]"}], "=", 
     RowBox[{
      RowBox[{"First", "[", 
       RowBox[{
        RowBox[{"S", "[", "t", "]"}], "/.", "sol"}], "]"}], "/.", 
      RowBox[{"t", "\[Rule]", "tt"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Atot", "[", "tt_", "]"}], "=", 
     RowBox[{
      RowBox[{"First", "[", 
       RowBox[{
        RowBox[{"A", "[", "t", "]"}], "/.", "sol"}], "]"}], "/.", 
      RowBox[{"t", "\[Rule]", "tt"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Itot", "[", "tt_", "]"}], "=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"First", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"II", "[", "k", "]"}], "[", "t", "]"}], "/.", "sol"}], 
          "]"}], ")"}], "/.", 
        RowBox[{"t", "\[Rule]", "tt"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Ltot", "[", "tt_", "]"}], "=", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"First", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"LL", "[", "k", "]"}], "[", "t", "]"}], "/.", "sol"}], 
          "]"}], ")"}], "/.", 
        RowBox[{"t", "\[Rule]", "tt"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"MTBI", "[", "tt_", "]"}], ":=", 
