         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"x", ">", 
            RowBox[{"1", "-", "fmin"}]}], ",", 
           RowBox[{"1", "-", "fmin"}], ",", "x"}], "]"}]}], "]"}]}], "]"}]}], 
    ";"}], "\n", 
